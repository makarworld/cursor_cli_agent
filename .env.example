# =============================================================================
# Cursor CLI Agent - Конфигурация Docker Compose
# Скопируйте в .env и заполните значения
# =============================================================================

# -----------------------------------------------------------------------------
# CloudCLI (веб-интерфейс)
# -----------------------------------------------------------------------------
# Порт веб-интерфейса (доступ: http://<сервер>:3001)
CLOUDCLI_PORT=3001

# -----------------------------------------------------------------------------
# Telegram бот
# -----------------------------------------------------------------------------
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Разрешённые Telegram user ID (через запятую)
# Узнать свой ID: напишите @userinfobot в Telegram
ALLOWED_USER_IDS=123456789

# Прокси для Telegram API (если заблокирован на сервере)
# Форматы: host:port:user:pass | host:port | socks5://user:pass@host:port
# TELEGRAM_PROXY=178.171.42.127:9654:login:password
# TELEGRAM_PROXY_TYPE=socks5

# -----------------------------------------------------------------------------
# Cursor CLI (для headless/Telegram бота)
# -----------------------------------------------------------------------------
# API ключ Cursor: https://cursor.com/dashboard?tab=background-agents
CURSOR_API_KEY=your_cursor_api_key_here

# Таймаут выполнения запроса (секунды)
CURSOR_TIMEOUT_SECONDS=300

# Путь к cursor-agent (по умолчанию: cursor-agent)
# Если установлен как "agent", укажите: CURSOR_CLI_PATH=agent
CURSOR_CLI_PATH=agent

# Модель Cursor (по умолчанию: auto)
# Другие: gpt-5.3-codex, gpt-5.2, gpt-5.2-codex и т.д.
# CURSOR_MODEL=auto

# Глобальный промпт, добавляемый при создании нового чата (после /new или первый запрос)
# По умолчанию загружается из telegram-bot/default_prompt.txt
# Можно переопределить через env (если задан — файл игнорируется)
# DEFAULT_PROMPT=Отвечай на всё только в формате markdown.

# Файл пользовательских промптов (по умолчанию: /workspace/.bot/user_prompts.json)
# Каждый пользователь может задать свой промпт через /set_prompt
# USER_PROMPTS_FILE=/workspace/.bot/user_prompts.json

# Директория для отчётов об ошибках (при ENTITY_TEXT_INVALID и др.)
# ERROR_REPORTS_DIR=/workspace/.bot/errors

# -----------------------------------------------------------------------------
# Самомодификация бота (правка своего кода, git-коммиты, откат)
# -----------------------------------------------------------------------------
# Включить самомодификацию (требует volume .:/workspace/cursor_cli_agent в docker-compose)
SELF_MODIFY_ENABLED=true

# Автоматически чинить бота при критических ошибках
SELF_MODIFY_AUTO_FIX=true

# Требовать кодовое слово в обычных сообщениях для правок кода бота (/self_fix — без слова)
SELF_MODIFY_CODEWORD_REQUIRED=true

# Список кодовых слов через запятую (регистр не важен)
# SELF_MODIFY_CODEWORDS=бурмалда,бурмалди

# Лимит автофиксов в час (защита от бесконечного цикла)
# SELF_MODIFY_MAX_PER_HOUR=5

# Имя и email для git-коммитов бота
# GIT_USER_NAME=cursor-telegram-bot
# GIT_USER_EMAIL=bot@cursor-cli-agent.local
