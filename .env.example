# =============================================================================
# Cursor CLI Agent - Конфигурация Docker Compose
# Скопируйте в .env и заполните значения
# =============================================================================

# -----------------------------------------------------------------------------
# CloudCLI (веб-интерфейс)
# -----------------------------------------------------------------------------
# Порт веб-интерфейса (доступ: http://<сервер>:3001)
CLOUDCLI_PORT=3001

# -----------------------------------------------------------------------------
# Telegram бот
# -----------------------------------------------------------------------------
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Разрешённые Telegram user ID (через запятую)
# Узнать свой ID: напишите @userinfobot в Telegram
ALLOWED_USER_IDS=123456789

# -----------------------------------------------------------------------------
# Cursor CLI (для headless/Telegram бота)
# -----------------------------------------------------------------------------
# API ключ Cursor: https://cursor.com/dashboard?tab=background-agents
CURSOR_API_KEY=your_cursor_api_key_here

# Таймаут выполнения запроса (секунды)
CURSOR_TIMEOUT_SECONDS=300

# Путь к cursor-agent (по умолчанию: cursor-agent)
# Если установлен как "agent", укажите: CURSOR_CLI_PATH=agent
CURSOR_CLI_PATH=agent

# Модель Cursor (по умолчанию: Composer 1.5)
# Другие: auto, Claude 4.6 Sonnet, GPT-5.2, Gemini 3 Flash и т.д.
# CURSOR_MODEL=Composer 1.5

# Промпт, добавляемый один раз при создании нового чата (после /new или первый запрос)
# Оставьте пустым, чтобы оставить промпт по умолчанию
# DEFAULT_PROMPT=Отвечай на всё только в формате markdown.

# Файл пользовательских промптов (по умолчанию: /workspace/.bot/user_prompts.json)
# Каждый пользователь может задать свой промпт через /set_prompt
# USER_PROMPTS_FILE=/workspace/.bot/user_prompts.json

# Директория для отчётов об ошибках (при ENTITY_TEXT_INVALID и др.)
# ERROR_REPORTS_DIR=/workspace/.bot/errors
